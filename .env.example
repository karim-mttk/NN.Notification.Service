# Application
PORT=5070
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>?schema=public"

# JWT (must match Auth Server)
JWT_SECRET_KEY=<your-jwt-secret>
JWT_ISSUER=AuthenticationServer
JWT_AUDIENCE=AuthenticationServerUsers

# Auth Server (for service-to-service tokens)
AUTH_API_URL=http://auth_server_api:8080
AUTH_SERVICE_API_KEY=

# Downstream services
OPERATIONS_API_URL=http://nn-operational-backend:8080
EMAIL_API_URL=http://nn-email-service:5000

# Kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_CONSUMER_GROUP=notification-dispatcher
KAFKA_PAYMENT_EVENTS_TOPIC=payment.events
KAFKA_NOTIFICATIONS_TOPIC=notifications.realtime
KAFKA_EMAILS_OUTBOUND_TOPIC=emails.outbound

# Logging
LOG_LEVEL=info
