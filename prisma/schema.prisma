// NN.Notification.Service Prisma schema.
// Stores per-user, per-tenant notifications so the platform frontend can
// render a bell with unread count + history.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationCategory {
  payment
  estimate
  system
  email
  shipping
  inventory
}

enum NotificationSeverity {
  info
  success
  warn
  error
}

model Notification {
  id          String                @id @default(uuid()) @db.Uuid
  tenantId    String                @db.Uuid
  /// null = broadcast to whole tenant
  userId      String?               @db.Uuid

  category    NotificationCategory
  severity    NotificationSeverity  @default(info)

  /// Short headline (e.g. "Estimate paid")
  title       String                @db.VarChar(200)
  /// Longer text shown in the notification list
  message     String                @db.VarChar(2000)

  /// Optional link the bell should navigate to when clicked
  actionUrl   String?               @db.VarChar(2000)
  /// Free-form payload (estimateId, sessionId, amount, …)
  data        Json?

  /// Source event id (e.g. Stripe cs_xxx) for idempotent inserts
  sourceEventId  String?            @db.VarChar(255)
  sourceTopic    String?            @db.VarChar(120)

  /// Legacy single-row read flag. Kept for back-compat with rows written
  /// before per-user receipts were introduced. New read state is recorded
  /// in `NotificationReceipt` so a broadcast row can be unread for some
  /// users while another user has already read it.
  isRead      Boolean               @default(false)
  readAt      DateTime?

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  receipts    NotificationReceipt[]

  @@index([tenantId, isRead, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([sourceEventId])
  @@map("Notifications")
}

/// Per-user read state for a notification. A row exists only when `userId`
/// has read `notificationId`. Absence => unread for that user. This lets a
/// broadcast notification (Notification.userId == null) be "read" by one
/// operator without flipping the bell for everyone else in the org.
model NotificationReceipt {
  notificationId String       @db.Uuid
  userId         String       @db.Uuid
  readAt         DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@index([userId, readAt])
  @@map("NotificationReceipts")
}

/// Per-user, per-tenant cutoff that anchors the earliest notification a user
/// is allowed to see in a given tenant. A row is lazily created the first
/// time a user touches the bell for that tenant (list / unreadCount /
/// markRead / markAllRead). Notifications with `createdAt < sinceAt` are
/// invisible to that user. This prevents brand-new users from inheriting
/// the entire historical broadcast feed of the org/dashboard they joined,
/// and stops cross-tenant leakage of legacy rows.
model NotificationVisibilityCutoff {
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  sinceAt   DateTime @default(now())

  @@id([tenantId, userId])
  @@index([userId])
  @@map("NotificationVisibilityCutoffs")
}